# Logging Configuration
LOGLEVEL=info

# File Scanning
SCAN_ROOT=./documents

# Embedding Model (fastembed)
# Options: BAAI/bge-small-en-v1.5 (default, 384d), BAAI/bge-base-en-v1.5 (768d), etc.
# See: https://qdrant.github.io/fastembed/examples/Supported_Models/
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Chunking Configuration
# CHUNK_SIZE: Target chunk size in tokens (1 token ≈ 0.75 words)
CHUNK_SIZE=512

# OVERLAP_SIZE: Overlap between chunks for semantic continuity
OVERLAP_SIZE=50

# Vector Database (Qdrant)
# QDRANT_URL: Connection URL for Qdrant vector database
QDRANT_URL=http://localhost:6333

# QDRANT_API_KEY: API key for Qdrant authentication (optional)
# Leave unset or empty for unauthenticated local instances
# QDRANT_API_KEY=

# QDRANT_PERSISTENCE_PATH: Path for persistent storage
# Set to "none" or empty for in-memory mode (development/testing)
# For production, use a path like ./data/qdrant
QDRANT_PERSISTENCE_PATH=./data/qdrant

# MCP Server Configuration
MCP_HOST=localhost
MCP_PORT=5000
